# Virtualenvs (kept outside repo, but guard anyway)
neural-apc-mbrl-env/
venv/
.venv/

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.pytest_cache/

# Torch / Inductor caches
_inductor_cache/
*.pt
*.pth

# ONNX / model artifacts
*.onnx

# Training outputs
logs/
output/
experiment_runs/
experiment_runs_*/

# Editor / OS
.vscode/
.idea/
.DS_Store
*.swp

# Transient build / install logs (e.g. venv pip-install output)
.venv_build.log
*.build.log
# Smoke-test SCRATCH artifacts (output dirs / images), but keep the .py harnesses
_smoke_*
!tools/_smoke_*.py

# Vision API credentials (never commit secrets)
vision_endpoints.txt
